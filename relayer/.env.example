# =============================================================================
# ChainBridge Relayer Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values
# NEVER commit .env file to version control
# =============================================================================

# =============================================================================
# RELAYER SETTINGS
# =============================================================================
RELAYER_NAME=relayer-01
RELAYER_FEE_BPS=10
RELAYER_MIN_FEE=1000
RELAYER_MAX_FEE=1000000
RELAYER_MAX_CONCURRENT_SWAPS=10

# Maximum exponential backoff delay in seconds between transaction retries.
# The backoff sequence (2, 4, 8, …) is capped at this value. Default: 300 (5 minutes).
MAX_RETRY_BACKOFF_SECS=300

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
RUST_LOG=info

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://chainbridge:password@localhost:5432/relayer

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://:password@localhost:6379/0

# =============================================================================
# STELLAR / SOROBAN
# =============================================================================
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
CHAINBRIDGE_CONTRACT_ID=

# Initial Soroban ledger sequence for Stellar event polling when no cursor is saved.
# Set to 0 (default) to start from genesis, or to the current ledger number to
# skip historical events on first startup.
STELLAR_START_LEDGER=0

# Relayer's Stellar account secret (for signing)
RELAYER_STELLAR_SECRET=

# =============================================================================
# BITCOIN
# =============================================================================
BITCOIN_NETWORK=testnet
BITCOIN_RPC_URL=http://localhost:8332
BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=
BITCOIN_CONFIRMATIONS=6

# Bitcoin private key (for signing HTLC transactions)
# BITCOIN_PRIVATE_KEY=

# =============================================================================
# ETHEREUM
# =============================================================================
ETHEREUM_NETWORK=testnet
ETHEREUM_RPC_URL=https://goerli.infura.io/v3/YOUR_INFURA_KEY
ETHEREUM_RPC_WS_URL=wss://goerli.infura.io/v3/YOUR_INFURA_KEY
ETHEREUM_CONFIRMATIONS=12

# Ethereum private key (for signing HTLC transactions)
# ETHEREUM_PRIVATE_KEY=

# HTLC Contract Address
ETHEREUM_HTLC_CONTRACT_ADDRESS=

# =============================================================================
# HEALTH CHECK
# =============================================================================
HEALTH_CHECK_PORT=8080

# =============================================================================
# METRICS
# =============================================================================
METRICS_ENABLED=true
METRICS_PORT=9090
